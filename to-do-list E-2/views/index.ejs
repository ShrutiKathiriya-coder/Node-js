<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>To-Do List</title>
     <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <!-- <link rel="stylesheet" href="/css/style.css" type="text/css"> --> -->
<style>
    body {
    font-family: 'Poppins', sans-serif;
    text-align: center;
    background: linear-gradient(135deg, #667eea, #764ba2);
    color: white;
    margin: 0;
    padding: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
}

/* Container */
.container {
    width: 400px;
    background: white;
    padding: 25px;
    border-radius: 15px;
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
    animation: fadeIn 1s ease-in-out;
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
}

/* Title */
h1 {
    font-size: 28px;
    color: #764ba2;
    margin-bottom: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
}

h1 i {
    margin-right: 10px;
}

/* Input Form */
form {
    margin-bottom: 20px;
}

input {
    width: 70%;
    padding: 10px;
    border: 2px solid #764ba2;
    border-radius: 6px;
    font-size: 16px;
    outline: none;
}

button {
    padding: 10px;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-size: 14px;
    transition: 0.3s;
}

/* Add Button */
.add-btn {
    background: #764ba2;
    color: white;
}

.add-btn:hover {
    background: #5a3b92;
}

/* Task Table */
table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 15px;
}

th, td {
    padding: 12px;
    border: 1px solid #ddd;
    text-align: left;
    color: black;
}

th {
    background: #764ba2;
    color: white;
}

td {
    background: #f8f9fa;
}

/* Task Buttons */
.complete-btn { background: #28a745; color: white; }
.complete-btn:hover { background: #218838; }

.undo-btn { background: #ffc107; color: black; }
.undo-btn:hover { background: #e0a800; }

.delete-btn { background: #dc3545; color: white; }
.delete-btn:hover { background: #c82333; }

/* Completed Task Styling */
.completed {
    text-decoration: line-through;
    color: gray;
}

</style>
</head>
<body>
    <div class="container">
        <h1><i class="fas fa-tasks"></i> To-Do List</h1>

        <!-- Task Input Form -->
        <form action="/add" method="POST">
            <input type="text" name="task" placeholder="Add a new task" required>
            <button type="submit" class="add-btn"><i class="fas fa-plus"></i></button>
        </form>

        <!-- Current Tasks -->
        <h2>Current Tasks</h2>
        <table>
            <thead>
                <tr>
                    <th>Task</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% tasks.filter(task => !task.completed).forEach(task => { %>
                    <tr>
                        <td><%= task.text %></td>
                        <td>
                            <form action="/complete/<%= task.id %>" method="POST" style="display:inline;">
                                <button type="submit" class="complete-btn"><i class="fas fa-check"></i></button>
                            </form>
                            <form action="/delete/<%= task.id %>" method="POST" style="display:inline;">
                                <button type="submit" class="delete-btn"><i class="fas fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>

        <!-- Completed Tasks -->
        <h2>Completed Tasks</h2>
        <table>
            <thead>
                <tr>
                    <th>Task</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% tasks.filter(task => task.completed).forEach(task => { %>
                    <tr class="completed">
                        <td><%= task.text %></td>
                        <td>
                            <form action="/undo/<%= task.id %>" method="POST" style="display:inline;">
                                <button type="submit" class="undo-btn"><i class="fas fa-undo"></i></button>
                            </form>
                            <form action="/delete/<%= task.id %>" method="POST" style="display:inline;">
                                <button type="submit" class="delete-btn"><i class="fas fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</body>
</html>
