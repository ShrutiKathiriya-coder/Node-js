<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Movie Browser</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">
  <style>
    body {
      margin: 0;
      font-family: 'Inter', sans-serif;
      background: #0d0d0d;
      color: #fff;
    }

    .app {
      display: flex;
      height: 100vh;
    }

    .sidebar {
      width: 240px;
      background-color: #1c1c1c;
      padding: 20px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .sidebar h2 {
      font-size: 20px;
      margin-bottom: 30px;
    }

    .sidebar a {
      display: block;
      color: #ccc;
      text-decoration: none;
      padding: 10px 0;
      transition: color 0.2s ease;
    }

    .sidebar a:hover {
      color: #fff;
    }

    .sidebar .next-releases {
      margin-top: 40px;
    }

    .content {
      flex: 1;
      padding: 30px;
    }

    .top-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .top-bar input {
      width: 60%;
      padding: 10px;
      background: #2a2a2a;
      border: none;
      border-radius: 8px;
      color: #fff;
    }

    .top-bar .add-btn {
      background-color: #03a9f4;
      color: #fff;
      padding: 10px 20px;
      border: none;
      border-radius: 8px;
      text-decoration: none;
    }

    .movie-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 20px;
      margin-top: 30px;
    }

    .movie-card {
      background-color: #1e1e1e;
      border-radius: 15px;
      overflow: hidden;
      text-align: center;
      padding: 10px;
    }

    .movie-card img {
      width: 100%;
      border-radius: 10px;
      height: 250px;
      object-fit: cover;
    }

    .movie-card h4 {
      margin: 10px 0 5px;
    }

    .movie-card p {
      font-size: 0.9em;
      color: #aaa;
    }
  </style>
</head>
<body>
  <div class="app">
    <aside class="sidebar">
      <div>
        <h2>🎬 WC Studio</h2>
        <a href="#">Home</a>
        <a href="#">Category</a>
        <a href="#">Favorites</a>
        <a href="#">Premier</a>
        <a href="#">New</a>

        <div class="next-releases">
          <h3>Next Releases</h3>
          <ul style="padding-left: 0; list-style: none;">
            <li>🟣 The Torch</li>
            <li>🔵 Gateway Effect</li>
            <li>🟠 Something Strange 3</li>
            <li>🔴 Norlanders War</li>
          </ul>
        </div>
      </div>
    </aside>

    <main class="content">
      <div class="top-bar">
        <input type="text" placeholder="Search for movies...">
        <a href="add.html" class="add-btn">➕ Add Movie</a>
      </div>

      <div class="movie-grid">
        <!-- Repeatable card -->
        <div class="movie-card">
          <img src="https://via.placeholder.com/180x250" alt="Red Riding Hood">
          <h4>Red Riding Hood</h4>
          <p>Fantasy | ⭐ 8.5</p>
        </div>
        <div class="movie-card">
          <img src="https://via.placeholder.com/180x250" alt="Freedom">
          <h4>Freedom</h4>
          <p>Action | ⭐ 9.1</p>
        </div>
        <!-- Add more cards as needed -->
      </div>
    </main>
  </div>
</body>
</html>
