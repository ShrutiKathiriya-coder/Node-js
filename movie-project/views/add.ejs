<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Add Movie</title>
  <style>
    body {
      margin: 0;
      background-color: #0f0f0f;
      color: #fff;
      font-family: 'Inter', sans-serif;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
    }

    form {
      background: #1f1f1f;
      padding: 30px;
      border-radius: 15px;
      width: 400px;
      display: flex;
      flex-direction: column;
      gap: 15px;
    }

    input, textarea {
      background: #2a2a2a;
      border: none;
      padding: 10px;
      color: #fff;
      border-radius: 8px;
    }

    button {
      background: #03a9f4;
      border: none;
      padding: 12px;
      border-radius: 8px;
      color: white;
      font-weight: bold;
      cursor: pointer;
    }
  </style>
</head>
<body>
  <form>
    <h2>Add New Movie</h2>
    <input type="text" placeholder="Title" required>
    <textarea placeholder="Description" rows="3"></textarea>
    <input type="text" placeholder="Genre">
    <input type="date">
    <input type="number" step="0.1" placeholder="Rating">
    <input type="text" placeholder="Poster URL">
    <button type="submit">Save</button>
  </form>
</body>
</html>
