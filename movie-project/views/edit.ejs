<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Edit Movie</title>
  <style>
    body {
      margin: 0;
      background-color: #0f0f0f;
      color: #fff;
      font-family: 'Inter', sans-serif;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
    }

    form {
      background: #1f1f1f;
      padding: 30px;
      border-radius: 15px;
      width: 400px;
      display: flex;
      flex-direction: column;
      gap: 15px;
    }

    input, textarea {
      background: #2a2a2a;
      border: none;
      padding: 10px;
      color: #fff;
      border-radius: 8px;
    }

    button {
      background: #ffc107;
      border: none;
      padding: 12px;
      border-radius: 8px;
      color: black;
      font-weight: bold;
      cursor: pointer;
    }
  </style>
</head>
<body>
  <form>
    <h2>Edit Movie</h2>
    <input type="text" value="Movie Title">
    <textarea rows="3">Movie description here</textarea>
    <input type="text" value="Genre">
    <input type="date" value="2025-01-01">
    <input type="number" step="0.1" value="8.0">
    <input type="text" value="Poster URL">
    <button type="submit">Update</button>
  </form>
</body>
</html>
